# Sao chép file này thành ".env" rồi điền khóa API của bạn.
# Lấy khóa miễn phí tại: https://aistudio.google.com/apikey
GEMINI_API_KEY=

# (Tùy chọn) Ghi đè tên model nếu Google đổi tên:
# GEMINI_MODEL_PRO=gemini-3-pro-image
# GEMINI_MODEL_FLASH=gemini-3.1-flash-image

# --- Engine thay thế: Replicate (SEED thật + ControlNet, giữ hình học chính xác) ---
# Lấy token tại: https://replicate.com/account/api-tokens
REPLICATE_API_TOKEN=
# (Tùy chọn) Ghi đè model nếu muốn dùng model khác trên Replicate:
# REPLICATE_MODEL=black-forest-labs/flux-depth-dev
# REPLICATE_INPAINT_MODEL=black-forest-labs/flux-fill-dev
